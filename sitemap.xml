<?xml version="1.0" encoding="UTF-8"?>
<!--
  PGT & HO Pay Justice Pakistan — Sitemap
  2026 best practice: only <loc> and <lastmod> — Google ignores <priority> and <changefreq>
  Hash anchors (#section) are not valid separate URLs — only the root page is listed
  Update <lastmod> only when meaningful content actually changes
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">

  <!--
    ROOT PAGE — the only real indexable URL for a single-page app.
    All sections (#journey, #petition, etc.) are anchor fragments, not separate pages.
    Google cannot index anchor fragments as independent URLs.
    The root page contains ALL content, so all keywords are discoverable from here.
  -->
  <url>
    <loc>https://pgthopayjustice.github.io/</loc>
    <lastmod>2026-06-24</lastmod>
    <xhtml:link
      rel="alternate"
      hreflang="en-PK"
      href="https://pgthopayjustice.github.io/"/>
  </url>

</urlset>
